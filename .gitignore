# Project: Nivelli app
# Purpose: Ignore unnecessary and sensitive files for version control

# =========================
# Environment & Secrets
# =========================
.env
.env.*
.envrc
*token.json*
*credentials.json*

# =========================
# Python Cache & Compiled
# =========================
__pycache__/
*.py[cod]
*$py.class
frontend/.metro-cache/

# =========================
# Virtual Environments
# =========================
.venv/
venv/
env/
ENV/

# =========================
# Node / Frontend Dependencies
# =========================
node_modules/
.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =========================
# Logs & Reports
# =========================
*.log
coverage/
htmlcov/
.pytest_cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =========================
# Build & Distribution
# =========================
build/
dist/
*.egg-info/
.next/
out/

# =========================
# IDE / Editor
# =========================
.vscode/
.idea/

# =========================
# System Files
# =========================
.DS_Store
Thumbs.db

# =========================
# Testing / Temp
# =========================
.ipynb_checkpoints/

# =========================
# Deployment / Cloud
# =========================
.vercel

# =========================
# Data / Local Databases
# =========================
agenthub/agents/youtube/db

# =========================
# Archives & Large Files
# =========================
*.zip
*.tar
*.tar.gz
*.tgz

# =========================
# Project Specific
# =========================
.emergent/
memory/
.cursorignore
.cursorindexingignore