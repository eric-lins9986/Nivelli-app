  "instructions_to_main_agent": [
    "CRITICAL: This is a React Native project. DO NOT use HTML tags (div, span, h1). Use <View>, <Text>, <Pressable>, <ScrollView>.",
    "CRITICAL: DO NOT use 'className' or Tailwind classes. They are NOT configured. Use `style={styles.container}` and `StyleSheet.create({})`.",
    "CRITICAL: Adhere to the 'Classical Minimalism' theme. Use the exact hex codes provided.",
    "NAVIGATION: Use `expo-router`. File based routing in `app/` directory.",
    "ICONS: Use `<Ionicons name='...' size={24} color={theme.colors.text.primary} />` from `@expo/vector-icons`.",
    "FONTS: Use system fonts but style them effectively. 'serif' for headings, 'sans-serif' for body.",
    "DATA-TESTID: Add `testID` prop to all interactive elements (React Native uses `testID` not `data-testid`).",
    "BACKEND: Connect to the Python FastAPI backend provided in `/app/backend`.",
    "MVP SCOPE: Implement ONLY the 3 screens requested. Do not add charts or categories."
  ],
  "UNIVERSAL_GUIDELINES_FOR_MAIN_AGENT": {
    "react_native_specifics": [
      "Use SafeAreaView from 'react-native-safe-area-context' for screen containers.",
      "Use KeyboardAvoidingView behavior='padding' for forms.",
      "Use StatusBar from 'expo-status-bar' with style='dark'.",
      "Touchable elements must have a minimum dimension of 44x44 points."
    ],
    "code_style": [
      "Use Functional Components with Hooks.",
      "Keep styles in the same file as the component (colocated) using StyleSheet.create.",
      "Use TypeScript interfaces for props."
    ]
  }
